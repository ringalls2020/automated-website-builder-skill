{
  "name": "automated-website-builder-skill",
  "version": "0.1.0",
  "description": "Codex skill for finding local leads and turning them into Tocayo demo sites, transfer links, walkthrough videos, and cold outreach messages.",
  "homepage": "https://github.com/ringalls2020/automated-website-builder-skill#readme",
  "license": "MIT",
  "type": "module",
  "bin": {
    "automated-website-builder-skill": "./bin/install.js"
  },
  "files": [
    "bin",
    "automated-website-builder/SKILL.md",
    "automated-website-builder/agents",
    "automated-website-builder/references",
    "automated-website-builder/scripts/*.mjs",
    "automated-website-builder/scripts/*.py",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node --check bin/install.js && node --check automated-website-builder/scripts/render-demo-video.mjs && python3 -m py_compile automated-website-builder/scripts/normalize-leads.py"
  },
  "keywords": [
    "codex",
    "skill",
    "tocayo",
    "outreach",
    "prospecting",
    "local-business"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ringalls2020/automated-website-builder-skill.git"
  },
  "bugs": {
    "url": "https://github.com/ringalls2020/automated-website-builder-skill/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
